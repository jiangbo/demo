    // 小田第一次对话
    .{
        .id = 13,
        .lines = .{
            .{ .actor = .player, .content = "喂，小田。昨天你说剑圣有一把什么‘圣剑’，到底是怎么回事？" },
            .{ .actor = .xiaoTian, .content = "哦！这件事说来话长。我现在肚子很饿，想不起来了。" },
            .{ .actor = .player, .content = "如果我请你吃一顿呢？" },
            .{ .actor = .xiaoTian, .content = "我好象突然又想起来了。" },
            .{ .actor = .player, .content = "快说" },
            .{ .actor = .xiaoTian, .content = "‘圣剑’是大侠剑圣的成名兵器，据说无坚不摧、削铁如泥！" },
            .{ .actor = .xiaoTian, .content =
            \\当年他老人家就是凭借‘圣剑’一举击败了不可一世的
            \\大魔王。
            },
            .{ .actor = .player, .content = "那剑圣死后，‘圣剑’现在又在哪儿呢？" },
            .{ .actor = .xiaoTian, .content = "据说是遗失在了城外的森林里，再没有人见过了。" },
            .{ .actor = .player, .content = "真可惜啊！" },
            .{ .actor = .xiaoTian, .content = "我们走吧。" },
            .{ .actor = .player, .content = "去哪儿？" },
            .{ .actor = .xiaoTian, .content = "吃东西啊！！" },
            .{ .actor = .player, .content = "吃什么东西，我有事先走了，再见！" },
            .{ .actor = .xiaoTian, .content = "混蛋，站住……哼、我饶不了你！" },
        },
    },
    // 小田第二次对话
    .{
        .id = 14,
        .lines = .{
            .{ .actor = .xiaoTian, .content = "要是让大魔王当了国王，那老百姓就遭殃了！" },
            .{ .actor = .player, .content = "……" },
            .{ .actor = .xiaoTian, .content = "除非有人能找到“圣剑”，才能制止大魔王的阴谋！" },
            .{ .actor = .player, .content = "“圣剑”到底在什么地方呢？" },
            .{
                .actor = .xiaoTian,
                .content = "我也不知道，不过听说当年剑圣死时，“圣剑”遗失在了城外的森林中！",
