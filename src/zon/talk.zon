    // 营救柔儿
    .{
        .id = 29,
        .lines = .{
            .{ .actor = .rouEr, .content = "救命啊！" },
            .{ .actor = .rouEr, .content = "你们……你们……别这样，求求你们了。" },
            .{ .actor = .rouEr, .content = "我……我是不会跟你们走的，你们还是放了我吧……" },
            .{ .actor = .rouEr, .content = "呜……呜……" },
            .{ .actor = .daoBa, .content = "放了你？嘿嘿……别做梦了！" },
            .{ .actor = .daoBa, .content = "告诉你吧，我们大王看上你了，决定让你做他的押寨夫人。" },
            .{ .actor = .daoBa, .content = "嘿嘿……小娘子，你就乖乖的跟我们走吧。" },
            .{ .actor = .daoBa, .content = "哈哈……" },
            .{ .actor = .player, .content = "住手！放开她。" },
            .{ .actor = .daoBa, .content = "小子，你叫谁呢？" },
            .{ .actor = .player, .content = "叫你们住手！" },
            .{ .actor = .daoBa, .content = "秃鹰，听到了吗？他叫我们住手。" },
            .{ .actor = .tuYing, .content = "小子，识相的最好走远点，不然我就不客气了。" },
            .{ .actor = .player, .content = "再说一遍“住手，然后给我滚！”" },
            .{
                .actor = .tuYing,
                .content = "他妈的，你小子是不是活的不耐烦了？给老子敬酒不吃吃罚酒，好！今天就修理修理你！",
                .event = .startBattleThenTalk,
            },
            .{ .actor = .daoBa, .content = "好家伙，还有两下子嘛！" },
            .{
                .actor = .daoBa,
                .content = "看我的",
                .event = .startBattleThenTalk,
            },
            .{ .actor = .player, .content = "柔儿你没事吧？" },
            .{ .actor = .rouEr, .content = "呜……幸好你来了，不然……不然……" },
            .{ .actor = .player, .content = "好了，现在没事了，以后可要小心点。" },
            .{ .actor = .rouEr, .content = "我知道了，谢谢你小飞刀。" },
            .{ .actor = .player, .content = "想当年……[ 此处省略自夸文字一万 ]" },
            .{ .actor = .player, .content = "算了，不说了。" },
            .{ .actor = .player, .content = "我看，我得去会会他们的头头‘巫批’" },
            .{ .actor = .rouEr, .content = "你……你不要去，他们好凶的！" },
            .{ .actor = .player, .content = "放心，我不会有事的。" },
        },
    },
