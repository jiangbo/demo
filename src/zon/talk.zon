    // 大友第二次对话
    .{
        .id = 7,
        .lines = .{
            .{ .actor = .daYou, .content = "大魔王可厉害了！！" },
            .{ .actor = .player, .content = "有什么怕的，我会打败他。" },
            .{ .actor = .daYou, .content = "[你！   FUCK！]你知道大魔王在什么地方吗？" },
            .{ .actor = .player, .content = "什么地方？" },
            .{
                .actor = .daYou,
                .content = "告诉你，出城往东南方向走，过了一个小湖，就到了一片黄土地，大魔王的宫殿就在里面。",
            },
            .{ .actor = .player, .content = "吹牛的吧！你怎么知道？" },
            .{ .actor = .daYou, .content = "哎！[孺子不可教也！]" },
            .{ .actor = .daYou, .content = "不信就算了。" },
            .{
                .actor = .player,
                .content = "[难道是真的！]我好兴奋，因为终于……可以……可以……见到大魔王了[我的声音怎么这么颤抖？]",
