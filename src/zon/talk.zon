    // 大魔王出现
    .{
        .id = 32,
        .lines = .{
            .{ .actor = .player, .content = "咦！什么声音？" },
            .{ .actor = .player, .content = "怎么大家都好像很惊慌的样子？刚才不是还好好的嘛！" },
            .{ .actor = .xiaoTian, .content = "不好了，十年前被剑圣打败的大魔王，刚才突然又出现了。" },
            .{ .actor = .player, .content = "他干了些什么？" },
            .{
                .actor = .xiaoTian,
                .content = "大魔王杀进了皇宫，把美丽的公主给掳走了，还限国王在三天之内交出王位，不然，就要杀掉公主！",
            },
            .{ .actor = .player, .content = "什么！公主！ [我暗恋多年的公主！不行，绝对不行！]" },
            .{ .actor = .player, .content = "大魔王太阴险了，现在剑圣已经死了。谁还可以制止大魔王呢？" },
            .{ .actor = .xiaoTian, .content = "我看没有人可以了，除非……" },
            .{ .actor = .player, .content = "怎么样？" },
            .{ .actor = .xiaoTian, .content = "找到失落的‘圣剑’！，不过希望太渺茫了……" },
            .{ .actor = .xiaoTian, .content = "不跟你说了，我还是先到乡下去躲一躲吧。" },
            .{ .actor = .player, .content = "不行，不能让大魔王得逞。[等着吧。我一定会阻止这场浩劫的]" },
        },
    },
