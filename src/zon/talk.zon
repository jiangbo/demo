            },
            .{ .actor = .wuPi, .content = "啊……" },
            .{ .actor = .player, .content = "死吧！罪大恶极的强盗。" },
            .{ .actor = .wuPi, .content = "大哥，你一定要为我报仇啊！……" },
            .{
                .actor = .player,
                .content = "[ 难道大魔王就是他的大哥？等着吧！大魔王，我一定会阻止你的阴谋。 ]",
                .event = .showSwordTip,
            },
        },
    },
    // 进入宫殿提示
    .{
        .id = 37,
        .lines = .{
            .{
                .actor = .player,
                .content = "再过去就是大魔王的宫殿了，我还没找到‘圣剑’，进去等于是送死啊！",
            },
            .{ .actor = .player, .content = "还是先找‘圣剑’吧！" },
        },
    },
    // 公主
    .{
        .id = 38,
        .lines = .{
            .{ .actor = .player, .content = "公主！你还好吗？" },
            .{ .actor = .gongZhu, .content = "你是？" },
            .{ .actor = .player, .content = "我是来救你的，我叫小飞刀" },
            .{ .actor = .gongZhu, .content = "谢谢你来救我，父王现在怎么样了？" },
            .{ .actor = .player, .content = "你不要担心，国王很好。跟我走吧！" },
            .{ .actor = .gongZhu, .content = "不行，我被大魔王用魔法定住了，不能动。" },
            .{ .actor = .player, .content = "哪……怎么办？" },
            .{ .actor = .gongZhu, .content = "只有先打败大魔王。才能破了他的魔法！" },
            .{ .actor = .player, .content = "好，你等者！" },
            .{ .actor = .gongZhu, .content = "你要小心啊！大魔王非常狡猾。" },
            .{ .actor = .player, .content = "你放心吧，等我。" },
        },
    },
    // 大魔王和结局
    .{
        .id = 39,
        .lines = .{
            .{ .actor = .player, .content = "嗨，老头。看到大魔王了吗？" },
            .{ .actor = .daMoWang, .content = "大魔王啊！他从后门走了。" },
            .{ .actor = .player, .content = "是吗，谢谢你告诉我！" },
            .{ .actor = .daMoWang, .content = "不用谢，快去追吧！[嘿嘿，小子你上当了，去死吧！]" },
            .{ .actor = .player, .content = "[如此狡诈的目光，难道他就是大魔王？对，一定是的]" },
            .{ .actor = .player, .content = "不用演戏了，其实你就是大魔王，对吗？" },
            .{
                .actor = .daMoWang,
                .content = "……既然被你看穿了，那我就送你下地狱去吧！！！",
                .event = .startBattleThenTalk,
            },
            .{ .actor = .daMoWang, .content = "什么？这……这……" },
            .{ .actor = .daMoWang, .content = "不！不可能的！！绝对不可能的！！！" },
            .{
                .actor = .daMoWang,
                .content = "我纵横一生，经过了多少的大风大浪，想不到最后会死在一个毛头小子的手里，真是造化弄人啊！",
            },
            .{ .actor = .player, .content = "这叫做“多行不义必自毙！" },
            .{
                .actor = .player,
                .content = "就算你再强大、再厉害，但是，你如果要破坏人类的和平！就一定会得到报应的！",
            },
            .{
                .actor = .player,
                .content = "因为世界人民是不会在强权面前屈服的，相反你越是欺压他们，他们就越是会团结在一起。不管多强大的敌人，也一样可以击败！",
            },
            .{ .actor = .daMoWang, .content = "呼……呼…… 我终于明白了，不过已经太迟了" },
            .{ .actor = .daMoWang, .content = "就让我来生做个好人吧！永别了……" },
            .{ .actor = .daMoWang, .content = "……" },
            .{ .actor = .player, .content = "……" },
            .{ .actor = .player, .content = "[一切都结束了，从此‘白云城’又会恢复和平]" },
            .{ .actor = .player, .content = "希望以后永远都不要再发生战斗了……" },
            .{ .actor = .gongZhu, .content = "啊！……" },
            .{ .actor = .gongZhu, .content = "我可以动了" },
            .{ .actor = .player, .content = "太好了公主，魔法已经解除了，大魔王永远的死了！" },
            .{ .actor = .gongZhu, .content = "谢谢你，我的勇士！你挽救了整个国家！" },
            .{ .actor = .player, .content = "嘿嘿……其实也没什么！我只不过是做了我该做的事！" },
            .{ .actor = .gongZhu, .content = "我代表父王感谢你，你救了我！" },
            .{ .actor = .player, .content = "公主，我有一个想法……不知道该不该说？" },
            .{ .actor = .gongZhu, .content = "什么想法？" },
            .{ .actor = .player, .content = "你不要生气哦！" },
            .{ .actor = .gongZhu, .content = "我怎么会生气呢！" },
            .{
                .actor = .player,
                .content = "我……我……其实……其实一直都好喜欢公主！ [好紧张、好紧张！！！]",
            },
            .{ .actor = .gongZhu, .content = "你……你这人好……" },
            .{ .actor = .player, .content = "好什么？" },
            .{ .actor = .gongZhu, .content = "好那个……" },
            .{ .actor = .player, .content = "哪个？" },
            .{ .actor = .gongZhu, .content = "我不跟你说了，要说你跟我父王去说吧！（公主的脸红了）" },
            .{ .actor = .player, .content = "[太好了！她是答应我了]耶！" },
            .{
                .actor = .player,
                .content = "那我们这就走吧……………[THE END]",
                .event = .showEnding,
            },
        },
    },
}
