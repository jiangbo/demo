    // 小春春第一次对话
    .{
        .id = 3,
        .lines = .{
            .{ .actor = .xiaoChunChun, .content = "你好小飞刀，又见面了。" },
            .{ .actor = .player, .content = "你好" },
            .{ .actor = .xiaoChunChun, .content = "你知道吗！人家……人家……" },
