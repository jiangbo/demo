    // 小璐第一次对话
    .{
        .id = 11,
        .lines = .{
            .{ .actor = .player, .content = "嗨！小璐，你今天看起来可真漂亮啊！" },
            .{ .actor = .xiaoLu, .content = "[肉麻]是吗！你也很COOL哦。" },
