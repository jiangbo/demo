    // 小璐第二次对话
    .{
        .id = 12,
        .lines = .{
            .{ .actor = .player, .content = "小璐你不要怕，我会一直保护你的！" },
            .{ .actor = .xiaoLu, .content = "谢谢，不过还是先照顾好你自己吧。[笨蛋]" },
