    // 巫批战斗
    .{
        .id = 36,
        .lines = .{
            .{ .actor = .player, .content = "我找一下强盗头子‘巫批’。" },
            .{ .actor = .wuPi, .content = "我就是神勇无敌的巫批！呵呵……" },
            .{ .actor = .wuPi, .content = "害怕了吧！小子" },
