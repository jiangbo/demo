            .{ .actor = .xiaoChunChun, .content = "人家喜欢你，傻瓜！" },
            .{ .actor = .player, .content = "[天哪！最近真背:-(]" },
            .{ .actor = .player, .content = "是吗？那先借给我十个金币怎么样？" },
            .{ .actor = .xiaoChunChun, .content = "死鬼，就知道钱，不理你了……" },
            .{ .actor = .player, .content = "[谢天谢地！！]" },
